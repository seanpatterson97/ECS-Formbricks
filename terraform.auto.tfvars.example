########################################################################################################################
## Mandatory Variables
########################################################################################################################

domain_name = "" # The domain to deploy to. Include a subdomain (e.g. demo.mysite.com)
region = "" # The region to deploy to. Ex: us-east-1
tld_zone_id = "" # Top Level Domain, found in the Route53 console.

########################################################################################################################
